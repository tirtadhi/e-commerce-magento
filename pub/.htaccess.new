<IfModule mod_rewrite.c>
    RewriteEngine on
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)$ - [L]
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Add this below to ensure PHP is executed
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>
